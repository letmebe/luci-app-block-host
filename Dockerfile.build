FROM openwrt/sdk:23.05-x86-64

USER root

WORKDIR /workspace

# 复制插件到 SDK
COPY package/luci-app-hostblocker /workspace/package/luci-app-hostblocker/

# 更新 feeds 并安装依赖
RUN ./scripts/feeds update -a && \
    ./scripts/feeds install -a

# 配置并编译
RUN echo "CONFIG_PACKAGE_luci-app-hostblocker=y" >> .config && \
    make defconfig && \
    make package/luci-app-hostblocker/compile V=s

# 输出结果
CMD ["ls", "-la", "bin/packages/x86_64/"]
